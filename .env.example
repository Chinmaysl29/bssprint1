# ── Supabase ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# ── Google Maps APIs ───────────────────────────────────────────────────────────
# All four APIs can share the same key if enabled on the same GCP project
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_GEOCODING_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_DIRECTIONS_API_KEY=your_google_maps_api_key
